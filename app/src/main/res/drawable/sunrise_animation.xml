<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom gradient (sky) -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#FF7B4A"
                android:endColor="#4A90E2"
                android:type="linear" />
        </shape>
    </item>

    <!-- Top overlay (sun) - using fixed dp instead of percentage -->
    <item android:top="200dp">
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#00FFFFFF"
                android:endColor="#FFFFFF" />
        </shape>
    </item>
</layer-list>